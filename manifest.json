{
  "name": "Kill Cam Login",
  "description": "An extension to help you skip clicking the login button on Moodle and Panapto",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "notifications",
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.vle.cam.ac.uk/login/*",
        "https://cambridgelectures.cloud.panopto.eu/*",
        "https://shib.raven.cam.ac.uk/*",
        "https://login.microsoftonline.com/*"

      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "hello.html",
    "default_icon": "icon.png"
  },

  "background": {
    "service_worker": "background.js"
  }

}
