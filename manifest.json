{
  "name": "Skip Cam Login",
  "description": "Auto-click the login button on Moodle and Panopto so you skip the extra click.",
  "version": "1.3",
  "manifest_version": 3,
  "homepage_url": "https://github.com/sileneer/skip-cam-login",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "notifications",
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.vle.cam.ac.uk/*",
        "https://cambridgelectures.cloud.panopto.eu/Panopto/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "settings.html",
    "default_title": "Skip Cam Login",
    "default_icon": {
      "16": "icon.png",
      "24": "icon.png",
      "32": "icon.png",
      "48": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
