{
  "name": "Kill Cam Login",
  "description": "An extension to help you skip clicking the login button on Moodle and Panapto",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "notifications",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.vle.cam.ac.uk/login/*",
        "https://cambridgelectures.cloud.panopto.eu/Panopto/Pages/Auth/Login.aspx*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "settings.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
