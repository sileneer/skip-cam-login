{
  "name": "Kill Cam Login",
  "description": "An extension to help you skip clicking the login button on Moodle and Panopto",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "notifications",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.vle.cam.ac.uk/login/*",
        "https://cambridgelectures.cloud.panopto.eu/Panopto/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "settings.html",
    "default_title": "Kill Cam Login",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
